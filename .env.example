# ===========================================================
# LLM AYARLARI
# ===========================================================
LLM_PROVIDER=groq
GROQ_API_KEY=""
GOOGLE_API_KEY=""
LLM_MODEL=""
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ===========================================================
# EMBEDDING VE RERANKER AYARLARI
# ===========================================================
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=32
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=5

# ===========================================================
# VERITABANI AYARLARI (Docker tarafindan yonetilir)
# ===========================================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=documents

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ===========================================================
# RAG PIPELINE AYARLARI
# ===========================================================
PARENT_CHUNK_SIZE=800
PARENT_CHUNK_OVERLAP=100
CHILD_CHUNK_SIZE=200
CHILD_CHUNK_OVERLAP=50
HYBRID_SEARCH_TOP_K=20
FINAL_TOP_K=5

# ===========================================================
# SISTEM AYARLARI
# ===========================================================
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=/app/uploads

# ===========================================================
# FRONTEND API
# ===========================================================
VITE_API_URL=http://localhost:8000/api/v1
